APP_NAME=Personal Collaborative API
APP_ENV=development
APP_LOG_LEVEL=INFO
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/app_db
APP_REDIS_URL=redis://redis:6379/0
APP_MODEL_VERSION=dev
APP_HOME_CACHE_TTL_SECONDS=60
APP_CORS_ORIGINS=["http://localhost:3000"]
APP_GIT_SHA=local
RUN_MIGRATIONS_ON_START=false
APP_ARTIFACT_PATH=ml/artifacts/v1
